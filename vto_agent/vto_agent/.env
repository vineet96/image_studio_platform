# Copy to .env. ADK auto-loads .env from this folder.

# Required: GCP project for Vertex AI
GOOGLE_CLOUD_PROJECT=""

# Required: region that supports VTO + Nano Banana. NOT "global".
GOOGLE_CLOUD_LOCATION=us-central1

# Required: use Vertex AI (vs the public Gemini API key path)
GOOGLE_GENAI_USE_VERTEXAI=True
BRAND_PDF_BUCKET=""      # bucket name, no gs:// prefix
BRAND_PDF_PREFIX=brands/

# Optional: switch Nano Banana variants. Default is the GA model.
#   gemini-2.5-flash-image           — GA (default, broadly available)
#   gemini-3.1-flash-image-preview   — Nano Banana 2 (allowlist only)
#   gemini-3-pro-image-preview       — Nano Banana Pro (allowlist only)
# NANO_BANANA_MODEL=gemini-2.5-flash-image
