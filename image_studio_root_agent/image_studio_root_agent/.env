# Shared .env for the image_studio_root_agent. ADK auto-loads this from
# image_studio_root_agent/.env.

GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
BRAND_PDF_BUCKET=""       # bucket name, no gs:// prefix
BRAND_PDF_PREFIX=brands/

# Brand PDFs from Google Cloud Storage (optional).
# If set, the marketing-campaign and social-media pipelines auto-pull
# the newest .pdf from this bucket as the brand guidelines, so the
# user doesn't need to attach anything. Leave both empty to require
# the user to attach the PDF in chat.
#
# The bucket can be public ("anyone with the URL can read") OR readable
# by your deploy/runtime service account. For Agent Engine deployments,
# grant the engine SA roles/storage.objectViewer on the bucket.
# BRAND_PDF_BUCKET=my-brand-pdfs
# BRAND_PDF_PREFIX=brands/

# Local-disk output dir for the campaign agent (in addition to artifacts)
# CAMPAIGN_OUTPUT_DIR=./campaign_outputs

# Optional Nano Banana variant
# NANO_BANANA_MODEL=gemini-2.5-flash-image
