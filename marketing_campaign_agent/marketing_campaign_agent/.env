# Copy to .env. ADK auto-loads .env from this folder.
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
BRAND_PDF_BUCKET=""       # bucket name, no gs:// prefix
BRAND_PDF_PREFIX=brands/

# Brand PDFs from Google Cloud Storage (optional).
# If set, the brand_parser auto-picks the newest .pdf in this bucket and
# uses it as the brand guidelines, so the user doesn't need to attach
# anything. Leave both empty to use the chat-attached PDF flow.
# BRAND_PDF_BUCKET=my-brand-pdfs
# BRAND_PDF_PREFIX=brands/

# Local-disk output dir for generated PNGs / captions (in addition to artifacts)
# CAMPAIGN_OUTPUT_DIR=./campaign_outputs
